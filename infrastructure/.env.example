# Copy to .env and fill in values. Never commit .env to source control.

# PostgreSQL (local dev)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vaxai_vision
POSTGRES_USER=vaxai
POSTGRES_PASSWORD=vaxai_dev_password
DATABASE_URL=postgresql://vaxai:vaxai_dev_password@localhost:5432/vaxai_vision

# Redis (local dev)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=vaxai_redis_dev
REDIS_URL=redis://:vaxai_redis_dev@localhost:6379/0

# Session Redis DB (separate logical DB)
REDIS_SESSION_DB=1

# S3 / LocalStack (local dev)
AWS_ENDPOINT_URL=http://localhost:4566
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

S3_BUCKET_RAW=vaxai-raw-data
S3_BUCKET_PROCESSED=vaxai-processed-data
S3_BUCKET_MODELS=vaxai-model-artifacts
S3_BUCKET_REPORTS=vaxai-reports
S3_BUCKET_LOGS=vaxai-app-logs

# Flyway
FLYWAY_PASSWORD=vaxai_dev_password
