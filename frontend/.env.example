# API base URL
#
# Development: Vite dev server proxies /api → http://localhost:8000, so the
# default below is only used when running vite outside the proxy (e.g. tests).
VITE_API_URL=http://localhost:8000/api/v1

# Production (nginx proxy, default):
#   VITE_API_URL=/api/v1
#   nginx.conf proxies /api/ → VAXAI_BACKEND_URL (default: http://vaxai-backend:8000)
#
# Production (direct, no nginx proxy layer):
#   VITE_API_URL=https://api.vaxaivision.com/api/v1
#   Pass as docker build arg: --build-arg VITE_API_URL=https://api.vaxaivision.com/api/v1
