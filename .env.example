# --- Landing page (src/) -----------------------------------------------------
# Next.js 14 reads NEXT_PUBLIC_* vars into the client bundle at build time.
# Set these in the Vercel project settings (Environment Variables) for Production
# and Preview, then redeploy.

# API base for the AR stock-count demo. Leave blank to use same-origin.
NEXT_PUBLIC_API_URL=

# Google Apps Script Web App URL that forwards Contact Us + Waitlist
# submissions into the "Contact US and Waitlist" Google Sheet
# (1t0v1ABeqNZe26lCNlbxcOKDeBsW7Fu5dFgxpNIJWcfM).
# Deploy the script at docs/forms-integration/Code.gs and paste the /exec URL here.
NEXT_PUBLIC_FORMS_ENDPOINT=
